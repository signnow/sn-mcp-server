# SignNow API configuration
SIGNNOW_TOKEN=
SIGNNOW_APP_BASE=https://app3.signnow.com
SIGNNOW_API_BASE=https://api.signnow.com
SIGNNOW_CLIENT_ID=
SIGNNOW_CLIENT_SECRET=
SIGNNOW_API_BASIC_TOKEN=
SIGNNOW_PASSWORD=
SIGNNOW_USER_EMAIL=

# OAuth server configuration
OAUTH_ISSUER=https://lebedev.ngrok.app
RESOURCE_HTTP_URL=https://lebedev.ngrok.app/mcp
RESOURCE_SSE_URL=https://lebedev.ngrok.app/sse
ACCESS_TTL=3600
REFRESH_TTL=2592000
ALLOWED_REDIRECTS="http://localhost, http://127.0.0.1"

# OAuth RSA key configuration
OAUTH_RSA_PRIVATE_PEM=your_rsa_private_key_here
OAUTH_JWK_KID=mcp-dev-key 