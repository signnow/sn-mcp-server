    {
      "name": "list_all_templates",
      "title": "List templates and template groups",
      "description": "Get simplified list of all templates and template groups with basic information",
      "annotations": { "readOnlyHint": true, "destructiveHint": false, "idempotentHint": true, "openWorldHint": true },
      "tags": ["template", "template_group", "list"],
      "input": {
        "limit": { "type": "int", "required": false, "default": 50, "constraints": "ge=1, le=100", "description": "Maximum number of items to return (1-100, default 50)" },
        "offset": { "type": "int", "required": false, "default": 0, "constraints": "ge=0", "description": "Number of items to skip for pagination (default 0)" }
      },
      "output": {
        "model": "TemplateSummaryList",
        "fields": {
          "templates": { "type": "list[TemplateSummary]", "description": "List of template summaries" },
          "total_count": { "type": "int", "description": "Total number of templates across all pages" },
          "offset": { "type": "int", "default": 0, "description": "Number of items skipped" },
          "limit": { "type": "int", "default": 50, "description": "Maximum number of items in this page" },
          "has_more": { "type": "bool", "default": false, "description": "Whether more items exist beyond this page" }
        },
        "nested": {
          "TemplateSummary": {
            "id": { "type": "str", "description": "Template group ID" },
            "name": { "type": "str", "description": "Template group name" },
            "entity_type": { "type": "str", "description": "Type of entity: 'template' or 'template_group'" },
            "folder_id": { "type": "str | null", "description": "Folder ID if stored in folder" },
            "last_updated": { "type": "int", "description": "Unix timestamp of last update" },
            "is_prepared": { "type": "bool", "description": "Whether the group is ready for sending" },
            "roles": { "type": "list[str]", "description": "All unique roles from all templates in the group" }
          }
        }
      }
    },
    {
      "name": "list_documents",
      "title": "List documents and document groups",
      "description": "Get simplified list of documents and document groups with basic information. Returns both documents and document groups in a unified format.",
      "annotations": { "readOnlyHint": true, "destructiveHint": false, "idempotentHint": true, "openWorldHint": true },
      "tags": ["document", "document_group", "list"],
      "input": {
        "filter": { "type": "Literal['signed','pending','waiting-for-me','waiting-for-others','unsent'] | null", "required": false, "default": null, "description": "Filter by document group status (optional)" },
        "sortby": { "type": "Literal['updated','created','document-name'] | null", "required": false, "default": null, "description": "Sort by created date, updated date, or document name (optional)" },
        "order": { "type": "Literal['asc','desc'] | null", "required": false, "default": null, "description": "Order of sorting (optional, can be used only with sortby)" },
        "folder_id": { "type": "str | null", "required": false, "default": null, "description": "Filter by folder ID (optional)" },
        "expired_filter": { "type": "Literal['all','expired','not-expired']", "required": false, "default": "all", "description": "Filter by invite expiredness (optional, default: all)" },
        "limit": { "type": "int", "required": false, "default": 50, "constraints": "ge=1, le=100", "description": "Maximum number of items to return (1-100, default 50)" },
        "offset": { "type": "int", "required": false, "default": 0, "constraints": "ge=0", "description": "Number of items to skip for pagination (default 0)" }
      },
      "output": {
        "model": "SimplifiedDocumentGroupsResponse",
        "fields": {
          "document_groups": { "type": "list[SimplifiedDocumentGroup]", "description": "List of document groups" },
          "document_group_total_count": { "type": "int", "description": "Total number of document groups across all pages" },
          "offset": { "type": "int", "default": 0, "description": "Number of items skipped" },
          "limit": { "type": "int", "default": 50, "description": "Maximum number of items in this page" },
          "has_more": { "type": "bool", "default": false, "description": "Whether more items exist beyond this page" }
        },
        "nested": {
          "SimplifiedDocumentGroup": {
            "last_updated": { "type": "int", "description": "Unix timestamp of the last update" },
            "id": { "type": "str", "description": "Document group or document ID" },
            "name": { "type": "str", "description": "Name of the document group or document" },
            "entity_type": { "type": "str", "description": "Type of entity: 'document' or 'document_group'" },
            "invite": { "type": "SimplifiedInvite | null", "description": "Unified invite info" },
            "documents": { "type": "list[SimplifiedDocumentGroupDocument]", "description": "List of documents in this group" }
          },
          "SimplifiedDocumentGroupDocument": {
            "id": { "type": "str", "description": "Document ID" },
            "name": { "type": "str", "description": "Document name" },
            "roles": { "type": "list[str]", "description": "Roles defined for this document" }
          },
          "SimplifiedInvite": {
            "invite_id": { "type": "str | null", "description": "Invite ID if present" },
            "status": { "type": "str", "description": "Unified invite status: pending, created, completed, declined, expired, unknown" },
            "status_raw": { "type": "str | null", "description": "Raw group-level invite status as returned by SignNow" },
            "expires_at": { "type": "int | null", "description": "Unified invite expiration timestamp" },
            "expired": { "type": "bool", "default": false, "description": "Is invite expired" },
            "participants": { "type": "list[SimplifiedInviteParticipant]", "description": "List of invite participants" }
          },
          "SimplifiedInviteParticipant": {
            "email": { "type": "str | null", "description": "Participant email" },
            "role": { "type": "str | null", "description": "Role (for document field_invites)" },
            "action": { "type": "str | null", "description": "Action (for document-group invites)" },
            "order": { "type": "int | null", "description": "Signing order if present" },
            "status": { "type": "str | null", "description": "Raw participant status from API" },
            "created": { "type": "int | null", "description": "Unix created timestamp" },
            "updated": { "type": "int | null", "description": "Unix updated timestamp" },
            "expires_at": { "type": "int | null", "description": "Unix expiration timestamp" },
            "expired": { "type": "bool", "default": false, "description": "Is this participant expired" }
          }
        }
      }
    },
